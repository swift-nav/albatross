    hdrs = [
        "mock_model.h",
        "test_core_distribution.h",
        "test_covariance_utils.h",
        "test_models.h",
        "test_utils.h",
    ],
    copts = ["-std=c++17"],
    includes = ["."],
)

# Common test dependencies
TEST_DEPS = [
    "//:albatross",
    ":serialize-testsuite",
    ":albatross-test-common",
    "@zlib",
    "@gtest//:gtest_main",
    "@suitesparse//:spqr",
]

