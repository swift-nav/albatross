load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

# Clang sanitizer ignorelist applied to every test compile.  Suppressions live
# in //:sanitizers.supp; see that file for the rationale behind each entry.
# The flag is benign in non-sanitizer builds.
SANITIZER_IGNORELIST = "//:sanitizers.supp"

SANITIZER_INPUTS = [SANITIZER_IGNORELIST]

TEST_COPTS = [
    "-std=c++17",
    "-Wno-deprecated-declarations",
    "-fsanitize-ignorelist=$(location " + SANITIZER_IGNORELIST + ")",
]

cc_library(
    name = "serialize-testsuite",
    testonly = True,
    hdrs = ["test_serialize.h"],
    copts = ["-std=c++17"],
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = ["@gtest"],
)

cc_library(
    name = "albatross-test-common",
